{
  "mcpServers": {
    "Adobe Wiki Confluence": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--name",
        "adobe-wiki-confluence-ajefr",
        "--env-file",
        "~/.easymcp/adobe-mcp-servers/src/adobe-wiki/.env-ajefr",
        "-e",
        "REGION_NAME=local",
        "-e",
        "ENVIRONMENT_NAME=local",
        "adobe-wiki-confluence"
      ]
    }
  }
}