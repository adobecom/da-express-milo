{
  "name": "pdp-page-gen",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview --open /tools/pdp-page-gen/dist/",
    "proxy": "tsc -p tsconfig.server.json && mv server/dist/proxy.js server/dist/proxy.cjs && node server/dist/proxy.cjs",
    "proxy:watch": "tsc -p tsconfig.server.json --watch"
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.0.0",
    "koa": "^2.8.0",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-query": "^5.90.11",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "tsx": "^4.19.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2"
  }
}
