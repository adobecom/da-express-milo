# Copy this file to .env and fill in your values.

# IMS token for DA Admin API and HLX Admin API
DA_TOKEN=your_ims_token_here

# DA org and repo (defaults match the da-express-milo project)
DA_ORG=adobecom
DA_REPO=da-express-milo

# Server port (default: 3001)
PORT=3001

# Proxy used to bypass Zazzle CORS (only needed for /generate/pdp)
ZAZZLE_PROXY=https://proxy-worker.jingleh12345.workers.dev/proxy
